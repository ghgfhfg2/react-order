unt":0},"D:\\프로젝트\\react-order\\src\\index.js",[],"D:\\프로젝트\\react-order\\src\\reportWebVitals.js",[],"D:\\프로젝트\\react-order\\src\\App.js",["101"],"D:\\프로젝트\\react-order\\src\\redux\\reducers\\index.js",[],"D:\\프로젝트\\react-order\\src\\firebase.js",[],"D:\\프로젝트\\react-order\\src\\component\\Join.js",[],["102","103"],"D:\\프로젝트\\react-order\\src\\component\\Loading.js",[],"D:\\프로젝트\\react-order\\src\\component\\Login.js",[],"D:\\프로젝트\\react-order\\src\\component\\MyOrder.js",["104"],"import { Button } from \"antd\";\r\nimport React, { useState, useEffect } from \"react\";\r\nimport firebase from \"../firebase\";\r\nimport { Popover } from \"antd\";\r\nimport { commaNumber } from \"./CommonFunc\";\r\nimport { useSelector } from \"react-redux\";\r\nimport { OrderBox } from \"./Admin/AdminOrder\";\r\nimport Loading from \"./Loading\";\r\nimport { Empty } from \"antd\";\r\n\r\nfunction MyOrder() {\r\n  const userInfo = useSelector((state) => state.user.currentUser);\r\n  const [OrderList, setOrderList] = useState([]);\r\n  const [Nodata, setNodata] = useState(false);\r\n\r\n  useEffect(() => {\r\n    let mounted = true;\r\n    if (mounted) {\r\n      firebase\r\n        .database()\r\n        .ref(\"order\")\r\n        .orderByChild(\"order_uid\")\r\n        .equalTo(userInfo.uid)\r\n        .limitToFirst(30)\r\n        .on(\"value\", (snapshot) => {\r\n          let array = [];\r\n          snapshot.forEach(function (item) {\r\n            array.push({\r\n              ...item.val(),\r\n              key: item.key,\r\n            });\r\n          });\r\n          // eslint-disable-next-line array-callback-return\r\n          array.sort((a, b) => {\r\n            if (a.timestamp < b.timestamp) {\r\n              return 1;\r\n            }\r\n            if (a.timestamp > b.timestamp) {\r\n              return -1;\r\n            }\r\n          });\r\n          setOrderList(array);\r\n          if (array.length === 0) {\r\n            setNodata(true);\r\n          }\r\n        });\r\n    }\r\n    return function cleanup() {\r\n      firebase.database().ref(\"order\").off();\r\n      mounted = false;\r\n    };\r\n  }, []);\r\n\r\n  if (OrderList.length) {\r\n    return (\r\n      <>\r\n        <h3 className=\"title\">주문내역</h3>\r\n        <OrderBox>\r\n          {OrderList.map((list, index) => (\r\n            <div className={`list state_${list.order_state}`} key={index}>\r\n              <div className=\"prod\">\r\n                <div className=\"info-box\">\r\n                  <span className=\"info\">{list.prod_name}</span>\r\n                  {list.hot === \"hot\" ? (\r\n                    <span className=\"ic-hot\"></span>\r\n                  ) : list.hot === \"ice\" ? (\r\n                    <span className=\"ic-ice\"></span>\r\n                  ) : (\r\n                    \"\"\r\n                  )}\r\n                  <span className=\"info\">{list.amount}개</span>\r\n                  <div>\r\n                    {list.add && (\r\n                      <span className=\"info\">{list.add}</span>\r\n                    )}\r\n                    {list.add2 && (\r\n                      <span className=\"info\">{list.add2}</span>\r\n                    )}\r\n                  </div>\r\n                  {list.order_etc && (\r\n                    <Popover content={list.order_etc} trigger=\"click\">\r\n                      <Button type=\"default\">기타</Button>\r\n                    </Popover>\r\n                  )}\r\n                </div>\r\n                <span>{commaNumber(parseInt(list.price))}원</span>\r\n              </div>\r\n              <div className=\"state\">\r\n                <span className=\"date\">\r\n                  {list.order_time.split(\"|\")[0]}&nbsp; (\r\n                  {list.order_time.split(\"|\")[1]})\r\n                </span>\r\n                <span>{list.order_state === 0 ? \"대기중\" : \"완료\"}</span>\r\n              </div>\r\n            </div>\r\n          ))}\r\n        </OrderBox>\r\n      </>\r\n    );\r\n  } else if (Nodata) {\r\n    return (\r\n      <>\r\n        <Empty\r\n          description=\"주문내역이 없습니다.\"\r\n          image={Empty.PRESENTED_IMAGE_SIMPLE}\r\n        ></Empty>\r\n      </>\r\n    );\r\n  } else {\r\n    return (\r\n      <>\r\n        <Loading />\r\n      </>\r\n    );\r\n  }\r\n}\r\n\r\nexport default MyOrder;\r\n","D:\\프로젝트\\react-order\\src\\component\\Admin\\Admin.js",[],"D:\\프로젝트\\react-order\\src\\component\\Nav.js",[],"D:\\프로젝트\\react-order\\src\\component\\Admin\\AdminOrderList.js",[],"D:\\프로젝트\\react-order\\src\\component\\MyMenu.js",["105","106"],"D:\\프로젝트\\react-order\\src\\redux\\actions\\user_action.js",[],"D:\\프로젝트\\react-order\\src\\component\\Menu.js",["107","108"],"D:\\프로젝트\\react-order\\src\\component\\Admin\\AdminOrder.js",["109"],"import React, { useState, useEffect } from \"react\";\r\nimport { Button } from \"antd\";\r\nimport styled from \"styled-components\";\r\nimport firebase from \"../../firebase\";\r\nimport { Popover, Radio } from \"antd\";\r\nimport { commaNumber } from \"../CommonFunc\";\r\nimport { Howl } from \"howler\";\r\nimport src1 from \"../../jumun.mp3\";\r\nimport src2 from \"../../jumun2.mp3\";\r\nimport src3 from \"../../jumun3.mp3\";\r\nimport src4 from \"../../jumun4.mp3\";\r\nimport src5 from \"../../pling.mp3\";\r\nimport src6 from \"../../dding.mp3\";\r\nimport src7 from \"../../alert.mp3\";\r\n\r\nexport const OrderBox = styled.div`\r\n  width: 100%;\r\n  display: flex;\r\n  flex-wrap: wrap;\r\n  .list {\r\n    .ic-hot,\r\n    .ic-ice {\r\n      display: inline-block;\r\n      width: 12px;\r\n      height: 12px;\r\n      border-radius: 50%;\r\n      opacity: 0.4;\r\n      margin-right: 10px;\r\n      position: relative;\r\n      top: 1px;\r\n    }\r\n    .ic-hot {\r\n      background: #f02424;\r\n    }\r\n    .ic-ice {\r\n      background: #1890ff;\r\n    }\r\n    color: #888;\r\n    &.state_0 {\r\n      .ic-hot,\r\n      .ic-ice {\r\n        opacity: 0.85;\r\n      }\r\n      color: #555;\r\n      border-color: #e6f7ff;\r\n      animation: neon_blue 1.5s ease-in-out infinite alternate;\r\n      .info {\r\n        color: #111;\r\n        font-weight: 500;\r\n      }\r\n    }\r\n    .from {\r\n      border-bottom: 1px solid #ddd;\r\n      height: 30px;\r\n    }\r\n    diplay: flex;\r\n    flex-direction: column;\r\n    padding: 10px;\r\n    border: 1px solid #ddd;\r\n    border-radius: 10px;\r\n    width: calc(33.33% - 10px);\r\n    margin: 5px;\r\n    .from {\r\n      margin-bottom: 5px;\r\n    }\r\n    .date {\r\n      font-size: 12px;\r\n    }\r\n    .info-box {\r\n      display: flex;\r\n      align-items: center;\r\n      height: 28px;\r\n      .info {\r\n        margin-right: 7px;\r\n      }\r\n      .ant-btn {\r\n        height: 28px;\r\n        padding: 0 7px;\r\n        line-height: 1;\r\n        span {\r\n          height: 100%;\r\n          line-height: 28px;\r\n          font-size: 12px;\r\n        }\r\n      }\r\n    }\r\n    & > div {\r\n      display: flex;\r\n      justify-content: space-between;\r\n      align-items: center;\r\n      width: 100%;\r\n      padding: 0 4px;\r\n    }\r\n  }\r\n  @media all and (max-width: 1024px) {\r\n    .list {\r\n      width: calc(50% - 10px);\r\n    }\r\n  }\r\n  @media all and (max-width: 640px) {\r\n    .list {\r\n      width: 100%;\r\n      margin: 5px 0;\r\n    }\r\n  }\r\n`;\r\n\r\nfunction AdminOrder() {\r\n  const [SoundSelect, setSoundSelect] = useState();\r\n  useEffect(() => {\r\n    firebase\r\n      .database()\r\n      .ref(\"order\")\r\n      .child(\"sound\")\r\n      .once(\"value\")\r\n      .then((snapshot) => {\r\n        setSoundSelect(snapshot.val());\r\n      });\r\n  }, []);\r\n  const onSoundChange = (e) => {\r\n    setSoundSelect(e.target.value);\r\n    firebase.database().ref(\"order\").update({ sound: e.target.value });\r\n  };\r\n\r\n  const Sound = new Howl({\r\n    src: [SoundSelect],\r\n  });\r\n\r\n  const [OrderList, setOrderList] = useState([]);\r\n  useEffect(() => {\r\n    let mounted = true;\r\n    if (mounted) {\r\n      firebase\r\n        .database()\r\n        .ref(\"order\")\r\n        .orderByChild(\"order_state\")\r\n        .equalTo(0)\r\n        .on(\"value\", (snapshot) => {\r\n          let array = [];\r\n          snapshot.forEach(function (item) {\r\n            array.push({\r\n              ...item.val(),\r\n              key: item.key,\r\n            });\r\n          });\r\n          // eslint-disable-next-line array-callback-return\r\n          array.sort((a, b) => {\r\n            if (a.timestamp > b.timestamp) {\r\n              return 1;\r\n            }\r\n            if (a.timestamp < b.timestamp) {\r\n              return -1;\r\n            }\r\n          });\r\n          setOrderList(array);\r\n        });\r\n    }\r\n    return function cleanup() {\r\n      firebase.database().ref(\"order\").off();\r\n      mounted = false;\r\n    };\r\n  }, []);\r\n\r\n  useEffect(() => {\r\n    let mounted = true;\r\n    if (mounted) {\r\n      firebase\r\n        .database()\r\n        .ref(\"order_count\")\r\n        .on(\"value\", (snapshot) => {\r\n          Sound.play();\r\n        });\r\n    }\r\n    return function cleanup() {\r\n      firebase.database().ref(\"order_count\").off();\r\n      mounted = false;\r\n    };\r\n  }, [SoundSelect]);\r\n\r\n  const stateChange = (key) => {\r\n    if (window.confirm(\"완료하시겠습니까?\")) {\r\n      firebase.database().ref(\"order\").child(key).update({\r\n        order_state: 1,\r\n      });\r\n    }\r\n  };\r\n\r\n  return (\r\n    <>\r\n      <h3 className=\"title\">주문관리</h3>\r\n      <div style={{ marginBottom: \"15px\" }}>\r\n        <Radio.Group onChange={onSoundChange} value={SoundSelect}>\r\n          <Radio.Button value={src1}>주문-여자</Radio.Button>\r\n          <Radio.Button value={src2}>주문-남자</Radio.Button>\r\n          <Radio.Button value={src3}>주문-여자아이</Radio.Button>\r\n          <Radio.Button value={src4}>주문-남자아이</Radio.Button>\r\n          <Radio.Button value={src5}>효과음1</Radio.Button>\r\n          <Radio.Button value={src6}>효과음2</Radio.Button>\r\n          <Radio.Button value={src7}>효과음3</Radio.Button>\r\n        </Radio.Group>\r\n      </div>\r\n      <OrderBox>\r\n        {OrderList.map((list, index) => (\r\n          <div className={`list state_${list.order_state}`} key={index}>\r\n            <span style={{ display: \"none\" }}>{list.key}</span>\r\n            <div className=\"from\">\r\n              <span>{list.order_name}</span>\r\n              <span>{list.order_part}</span>\r\n            </div>\r\n            <div className=\"prod\">\r\n              <div className=\"info-box\">\r\n                <span className=\"info\">{list.prod_name}</span>\r\n                {list.hot === \"hot\" ? (\r\n                  <span className=\"ic-hot\"></span>\r\n                ) : list.hot === \"ice\" ? (\r\n                  <span className=\"ic-ice\"></span>\r\n                ) : (\r\n                  \"\"\r\n                )}\r\n                <span className=\"info\">{list.amount}개</span>\r\n                {list.add && (\r\n                  <>\r\n                    <span className=\"info\">{list.add}</span>\r\n                    <span className=\"info\">{list.add2}</span>\r\n                  </>\r\n                )}\r\n                {list.order_etc && (\r\n                  <Popover content={list.order_etc} trigger=\"click\">\r\n                    <Button type=\"default\">기타</Button>\r\n                  </Popover>\r\n                )}\r\n              </div>\r\n              <span>{commaNumber(list.price)}원</span>\r\n            </div>\r\n            <div className=\"state\">\r\n              <span className=\"date\">\r\n                {list.order_time.split(\"|\")[0]}&nbsp; (\r\n                {list.order_time.split(\"|\")[1]})\r\n              </span>\r\n              <Button\r\n                onClick={() => {\r\n                  stateChange(list.key);\r\n                }}\r\n              >\r\n                완료처리\r\n              </Button>\r\n            </div>\r\n          </div>\r\n        ))}\r\n      </OrderBox>\r\n    </>\r\n  );\r\n}\r\n\r\nexport default AdminOrder;\r\n","D:\\프로젝트\\react-order\\src\\component\\Admin\\AdminProd.js",[],"D:\\프로젝트\\react-order\\src\\redux\\reducers\\user_reducer.js",[],"D:\\프로젝트\\react-order\\src\\firebaseConfig.js",[],"D:\\프로젝트\\react-order\\src\\component\\CommonFunc.js",[],"D:\\프로젝트\\react-order\\src\\redux\\actions\\types.js",[],"D:\\프로젝트\\react-order\\src\\component\\OrderModal.js",["110"],"D:\\프로젝트\\react-order\\src\\component\\Admin\\ImgUpload.js",[],"D:\\프로젝트\\react-order\\src\\component\\Admin\\ModifyModal.js",[],{"ruleId":"111","severity":1,"message":"112","line":37,"column":6,"nodeType":"113","endLine":37,"endColumn":8,"suggestions":"114"},{"ruleId":"115","replacedBy":"116"},{"ruleId":"117","replacedBy":"118"},{"ruleId":"111","severity":1,"message":"119","line":52,"column":6,"nodeType":"113","endLine":52,"endColumn":8,"suggestions":"120"},{"ruleId":"121","severity":1,"message":"122","line":141,"column":32,"nodeType":"123","messageId":"124","endLine":141,"endColumn":34},{"ruleId":"111","severity":1,"message":"125","line":156,"column":6,"nodeType":"113","endLine":156,"endColumn":16,"suggestions":"126"},{"ruleId":"111","severity":1,"message":"127","line":65,"column":27,"nodeType":"128","endLine":65,"endColumn":35},{"ruleId":"121","severity":1,"message":"122","line":119,"column":35,"nodeType":"123","messageId":"124","endLine":119,"endColumn":37},{"ruleId":"111","severity":1,"message":"129","line":178,"column":6,"nodeType":"113","endLine":178,"endColumn":19,"suggestions":"130"},{"ruleId":"131","severity":1,"message":"132","line":81,"column":10,"nodeType":"133","messageId":"134","endLine":81,"endColumn":21},"react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'dispatch' and 'history'. Either include them or remove the dependency array.","ArrayExpression",["135"],"no-native-reassign",["136"],"no-negated-in-lhs",["137"],"React Hook useEffect has a missing dependency: 'userInfo.uid'. Either include it or remove the dependency array.",["138"],"array-callback-return","Array.prototype.map() expects a return value from arrow function.","ArrowFunctionExpression","expectedInside","React Hook useEffect has missing dependencies: 'FavorItem', 'ProdItem', and 'userInfo.uid'. Either include them or remove the dependency array.",["139"],"Assignments to the 'b_soldout' variable from inside React Hook useEffect will be lost after each render. To preserve the value over time, store it in a useRef Hook and keep the mutable value in the '.current' property. Otherwise, you can move this variable directly inside useEffect.","CallExpression","React Hook useEffect has a missing dependency: 'Sound'. Either include it or remove the dependency array.",["140"],"no-unused-vars","'radioValue2' is assigned a value but never used.","Identifier","unusedVar",{"desc":"141","fix":"142"},"no-global-assign","no-unsafe-negation",{"desc":"143","fix":"144"},{"desc":"145","fix":"146"},{"desc":"147","fix":"148"},"Update the dependencies array to be: [dispatch, history]",{"range":"149","text":"150"},"Update the dependencies array to be: [userInfo.uid]",{"range":"151","text":"152"},"Update the dependencies array to be: [FavorItem, ProdItem, SortItem, userInfo.uid]",{"range":"153","text":"154"},"Update the dependencies array to be: [Sound, SoundSelect]",{"range":"155","text":"156"},[1386,1388],"[dispatch, history]",[1532,1534],"[userInfo.uid]",[4717,4727],"[FavorItem, ProdItem, SortItem, userInfo.uid]",[4108,4121],"[Sound, SoundSelect]"]