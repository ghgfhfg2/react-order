unt":0},{"filePath":"66","messages":"67","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"68","usedDeprecatedRules":"69"},{"filePath":"70","messages":"71","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"72","messages":"73","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"74","messages":"75","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"69"},{"filePath":"76","messages":"77","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":"78","usedDeprecatedRules":"69"},{"filePath":"79","messages":"80","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"81","messages":"82","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"83","messages":"84","errorCount":0,"warningCount":1,"fixableErrorCount":0,"fixableWarningCount":0,"source":null},{"filePath":"85","messages":"86","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"69"},{"filePath":"87","messages":"88","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"89","messages":"90","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"91","messages":"92","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"93","messages":"94","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"95","messages":"96","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"usedDeprecatedRules":"69"},{"filePath":"97","messages":"98","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"99","messages":"100","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"D:\\프로젝트\\react-order\\src\\index.js",[],"D:\\프로젝트\\react-order\\src\\reportWebVitals.js",[],"D:\\프로젝트\\react-order\\src\\App.js",["101"],"D:\\프로젝트\\react-order\\src\\redux\\reducers\\index.js",[],"D:\\프로젝트\\react-order\\src\\firebase.js",[],"D:\\프로젝트\\react-order\\src\\component\\Join.js",[],"D:\\프로젝트\\react-order\\src\\component\\Loading.js",[],"D:\\프로젝트\\react-order\\src\\component\\Login.js",[],"D:\\프로젝트\\react-order\\src\\component\\MyOrder.js",["102"],"import { Button } from \"antd\";\r\nimport React, { useState, useEffect } from \"react\";\r\nimport firebase from \"../firebase\";\r\nimport { Popover } from \"antd\";\r\nimport { commaNumber } from \"./CommonFunc\";\r\nimport { useSelector } from \"react-redux\";\r\nimport { OrderBox } from \"./Admin/AdminOrder\";\r\nimport Loading from \"./Loading\";\r\nimport { Empty } from 'antd';\r\n\r\nfunction MyOrder() {\r\n  const userInfo = useSelector((state) => state.user.currentUser);\r\n  const [OrderList, setOrderList] = useState([]);\r\n  const [Nodata, setNodata] = useState(false);\r\n\r\n  useEffect(() => {\r\n    let mounted = true;\r\n    if (mounted) {\r\n      firebase\r\n        .database()\r\n        .ref(\"order\")\r\n        .orderByChild(\"order_uid\")\r\n        .equalTo(userInfo.uid)\r\n        .limitToFirst(30)\r\n        .on(\"value\", (snapshot) => {          \r\n          let array = [];\r\n          snapshot.forEach(function (item) {\r\n            array.push({\r\n              ...item.val(),\r\n              key: item.key,\r\n            });\r\n          });          \r\n          // eslint-disable-next-line array-callback-return\r\n          array.sort((a, b) => {\r\n            if (a.timestamp < b.timestamp) {\r\n              return 1;\r\n            }\r\n            if (a.timestamp > b.timestamp) {\r\n              return -1;\r\n            }\r\n          });\r\n          setOrderList(array);\r\n          if(array.length === 0){\r\n              setNodata(true)\r\n          }\r\n        });\r\n    }\r\n    return function cleanup() {\r\n      mounted = false;\r\n    };\r\n  }, []);\r\n\r\n  if (OrderList.length) {\r\n    return (\r\n      <>\r\n        <h3 className=\"title\">주문내역</h3>\r\n        <OrderBox>\r\n          {OrderList.map((list, index) => (\r\n            <div className={`list state_${list.order_state}`} key={index}>\r\n              <div className=\"prod\">\r\n                <div className=\"info-box\">\r\n                  <span className=\"info\">{list.prod_name}</span>\r\n                  {list.hot === \"hot\" ? (\r\n                    <span className=\"ic-hot\"></span>\r\n                  ) : list.hot === \"ice\" ? (\r\n                    <span className=\"ic-ice\"></span>\r\n                  ) : (\r\n                    \"\"\r\n                  )}\r\n                  <span className=\"info\">{list.amount}개</span>\r\n                  <div>\r\n                  {\r\n                  list.add && list.add[0] &&\r\n                  <span className=\"info\">{list.add[0]}</span>\r\n                  }\r\n                  {\r\n                  list.add && list.add[1] &&\r\n                  <span className=\"info\">{list.add[1]}</span>\r\n                  }\r\n                  </div>\r\n                  {list.order_etc && (\r\n                    <Popover content={list.order_etc} trigger=\"click\">\r\n                      <Button type=\"default\">기타</Button>\r\n                    </Popover>\r\n                  )}\r\n                </div>\r\n                <span>{commaNumber(list.price)}원</span>\r\n              </div>\r\n              <div className=\"state\">\r\n                <span className=\"date\">\r\n                  {list.order_time.split(\"|\")[0]}&nbsp; (\r\n                  {list.order_time.split(\"|\")[1]})\r\n                </span>\r\n                <span>{list.order_state === 0 ? \"대기중\" : \"완료\"}</span>\r\n              </div>\r\n            </div>\r\n          ))}\r\n        </OrderBox>\r\n      </>\r\n    );\r\n  }else if(Nodata){\r\n    return (\r\n      <>\r\n        <Empty \r\n        description=\"주문내역이 없습니다.\"\r\n        image={Empty.PRESENTED_IMAGE_SIMPLE} \r\n        >          \r\n        </Empty>\r\n      </>\r\n    )\r\n  } else {\r\n    return (\r\n      <>\r\n        <Loading />\r\n      </>\r\n    );\r\n  }\r\n}\r\n\r\nexport default MyOrder;\r\n",["103","104"],"D:\\프로젝트\\react-order\\src\\component\\Admin\\Admin.js",[],"D:\\프로젝트\\react-order\\src\\component\\Nav.js",[],"D:\\프로젝트\\react-order\\src\\component\\Admin\\AdminOrderList.js",[],"D:\\프로젝트\\react-order\\src\\component\\MyMenu.js",["105"],"import React, { useState, useEffect } from \"react\";\r\nimport firebase from \"../firebase\";\r\nimport { ProdList } from \"./Admin/AdminProd\";\r\nimport OderModalPopup from \"./OrderModal\";\r\nimport { commaNumber } from \"./CommonFunc\";\r\nimport { useSelector } from \"react-redux\";\r\nimport Loading from \"./Loading\";\r\n\r\nfunction MyMenu() {\r\n  const userInfo = useSelector((state) => state.user.currentUser);\r\n\r\n  const [FavorItem, setFavorItem] = useState([]);\r\n  const [ProdItem, setProdItem] = useState([]);\r\n  const [SortItem, setSortItem] = useState(false);\r\n\r\n  let favor = [];\r\n  let favorName = [];\r\n  useEffect(() => {\r\n    let mounted = true;\r\n    if (mounted) {\r\n      async function getProdItem() {\r\n        await firebase\r\n          .database()\r\n          .ref(`users/${userInfo.uid}/favorite`)\r\n          .once(\"value\")\r\n          .then((snapshot) => {\r\n            snapshot.forEach(function (item) {\r\n              favorName.push(item.key);\r\n              favor.push({\r\n                name: item.key,\r\n                count: item.val().count,\r\n              });\r\n            });\r\n          });\r\n        setFavorItem(favor);\r\n        await firebase\r\n          .database()\r\n          .ref(\"products\")\r\n          .once(\"value\")\r\n          .then((snapshot) => {\r\n            let array = [];\r\n            snapshot.forEach(function (item) {\r\n              array.push({\r\n                uid: item.key,\r\n                name: item.val().name,\r\n                kal: item.val().kal,\r\n                hot: item.val().hot,\r\n                category: item.val().category,\r\n                image: item.val().image,\r\n                price: item.val().price,\r\n                add: item.val().add,\r\n              });\r\n            });\r\n            setProdItem(array);\r\n          });\r\n        setSortItem(true);\r\n        if (FavorItem && ProdItem) {\r\n          let array = ProdItem.concat();\r\n          array = array.filter((el) => {\r\n            return favorName.includes(el.name);\r\n          });\r\n          array.map((el, idx) => {\r\n            return Object.assign(el, FavorItem[idx]);\r\n          });\r\n          array.sort((a, b) => {\r\n            if (a.count > b.count) {\r\n              return -1;\r\n            }\r\n            if (a.count < b.count) {\r\n              return 1;\r\n            }\r\n            return 0;\r\n          });\r\n          array = array.slice(0, 10);\r\n          setProdItem(array);\r\n        }\r\n      }\r\n      getProdItem();\r\n    }\r\n    return function cleanup() {\r\n      mounted = false;\r\n    };\r\n  }, [SortItem]);\r\n\r\n  const [PosX, setPosX] = useState(0);\r\n  const [PosY, setPosY] = useState(0);\r\n  const [OnModal, setOnModal] = useState(false);\r\n  const [OrderItem, setOrderItem] = useState();\r\n  const orderHandler = (e, item) => {\r\n    setOrderItem(item);\r\n    setPosX(e.clientX);\r\n    setPosY(e.clientY);\r\n    setOnModal(true);\r\n  };\r\n  const onFinished = () => {\r\n    setOnModal(false);\r\n  };\r\n\r\n  return (\r\n    <>\r\n      <h3 className=\"title\">내가 많이 주문한 메뉴</h3>\r\n      {SortItem ? (\r\n        <ProdList>\r\n          {ProdItem.map((item, index) => (\r\n            <div\r\n              style={{ cursor: \"pointer\" }}\r\n              className={`ani-fadein list delay-${index}`}\r\n              key={index}\r\n              onClick={(e) => orderHandler(e, item)}\r\n            >\r\n              <div className=\"img\">\r\n                <span style={{ opacity: \"0.85\" }} className=\"kal\">\r\n                  {item.kal}kal\r\n                </span>\r\n                <img src={item.image} alt=\"\" />\r\n              </div>\r\n              <div className=\"admin-box\">\r\n                <div className=\"txt\" style={{ padding: \"0 10px\" }}>\r\n                  <span className=\"name\">{item.name}</span>\r\n                  <div className=\"flex-box between a-center\">\r\n                    <span className=\"hot\">{item.hot}</span>\r\n                    <span\r\n                      style={{\r\n                        textDecoration: \"line-through\",\r\n                        color: \"#888\",\r\n                      }}\r\n                      className=\"price\"\r\n                    >\r\n                      {commaNumber(item.price)}원\r\n                    </span>\r\n                  </div>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          ))}\r\n        </ProdList>\r\n      ) : (\r\n        <>\r\n          <Loading />\r\n        </>\r\n      )}\r\n      {OnModal && (\r\n        <OderModalPopup\r\n          onFinished={onFinished}\r\n          posx={PosX}\r\n          posy={PosY}\r\n          OrderItem={OrderItem}\r\n        />\r\n      )}\r\n    </>\r\n  );\r\n}\r\n\r\nexport default MyMenu;\r\n","D:\\프로젝트\\react-order\\src\\redux\\actions\\user_action.js",[],"D:\\프로젝트\\react-order\\src\\component\\Menu.js",["106"],"D:\\프로젝트\\react-order\\src\\component\\Admin\\AdminOrder.js",["107"],"D:\\프로젝트\\react-order\\src\\component\\Admin\\AdminProd.js",[],"D:\\프로젝트\\react-order\\src\\redux\\reducers\\user_reducer.js",[],"D:\\프로젝트\\react-order\\src\\firebaseConfig.js",[],"D:\\프로젝트\\react-order\\src\\component\\CommonFunc.js",[],"D:\\프로젝트\\react-order\\src\\redux\\actions\\types.js",[],"D:\\프로젝트\\react-order\\src\\component\\OrderModal.js",[],"D:\\프로젝트\\react-order\\src\\component\\Admin\\ImgUpload.js",[],"D:\\프로젝트\\react-order\\src\\component\\Admin\\ModifyModal.js",[],{"ruleId":"108","severity":1,"message":"109","line":37,"column":6,"nodeType":"110","endLine":37,"endColumn":8,"suggestions":"111"},{"ruleId":"108","severity":1,"message":"112","line":52,"column":6,"nodeType":"110","endLine":52,"endColumn":8,"suggestions":"113"},{"ruleId":"114","replacedBy":"115"},{"ruleId":"116","replacedBy":"117"},{"ruleId":"108","severity":1,"message":"118","line":83,"column":6,"nodeType":"110","endLine":83,"endColumn":16,"suggestions":"119"},{"ruleId":"108","severity":1,"message":"120","line":88,"column":6,"nodeType":"110","endLine":88,"endColumn":43,"suggestions":"121"},{"ruleId":"108","severity":1,"message":"122","line":178,"column":6,"nodeType":"110","endLine":178,"endColumn":19,"suggestions":"123"},"react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'dispatch' and 'history'. Either include them or remove the dependency array.","ArrayExpression",["124"],"React Hook useEffect has a missing dependency: 'userInfo.uid'. Either include it or remove the dependency array.",["125"],"no-native-reassign",["126"],"no-negated-in-lhs",["127"],"React Hook useEffect has missing dependencies: 'FavorItem', 'ProdItem', 'favor', 'favorName', and 'userInfo.uid'. Either include them or remove the dependency array.",["128"],"React Hook useEffect has a missing dependency: 'ProdItem'. Either include it or remove the dependency array.",["129"],"React Hook useEffect has a missing dependency: 'Sound'. Either include it or remove the dependency array.",["130"],{"desc":"131","fix":"132"},{"desc":"133","fix":"134"},"no-global-assign","no-unsafe-negation",{"desc":"135","fix":"136"},{"desc":"137","fix":"138"},{"desc":"139","fix":"140"},"Update the dependencies array to be: [dispatch, history]",{"range":"141","text":"142"},"Update the dependencies array to be: [userInfo.uid]",{"range":"143","text":"144"},"Update the dependencies array to be: [FavorItem, ProdItem, SortItem, favor, favorName, userInfo.uid]",{"range":"145","text":"146"},"Update the dependencies array to be: [CateRadio, searchInput, SearchAgain, ProdItem]",{"range":"147","text":"148"},"Update the dependencies array to be: [Sound, SoundSelect]",{"range":"149","text":"150"},[1377,1379],"[dispatch, history]",[1532,1534],"[userInfo.uid]",[2505,2515],"[FavorItem, ProdItem, SortItem, favor, favorName, userInfo.uid]",[2626,2663],"[CateRadio, searchInput, SearchAgain, ProdItem]",[4108,4121],"[Sound, SoundSelect]"]