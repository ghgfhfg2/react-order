Count":0},{"filePath":"90","messages":"91","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"92","messages":"93","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"94","messages":"95","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"96","messages":"97","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},{"filePath":"98","messages":"99","errorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0},"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\index.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\reportWebVitals.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\App.js",["100"],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\redux\\reducers\\index.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\firebase.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Join.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Admin\\Admin.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\MyOrder.js",["101","102","103","104"],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Loading.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Login.js",["105","106"],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Admin\\AdminOrder.js",["107"],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Admin\\AdminOrderList.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\redux\\actions\\user_action.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Menu.js",["108","109"],"import React, { useState, useEffect } from \"react\";\nimport firebase from \"../firebase\";\nimport { ProdList } from \"./Admin/AdminProd\";\nimport OderModalPopup from \"./OrderModal\";\nimport { commaNumber } from \"./CommonFunc\";\nimport Loading from \"./Loading\";\nimport { Radio, Input, Empty } from \"antd\";\nimport * as antIcon from \"react-icons/ai\";\nimport * as Hangul from \"hangul-js\";\nimport { useSelector } from \"react-redux\";\nconst { Search } = Input;\nconst _ = require(\"lodash\");\n\nfunction Menu() {\n  const userInfo = useSelector((state) => state.user.currentUser);\n  const [ProdItem, setProdItem] = useState([]);\n\n  //정렬 라디오버튼\n  const [CateRadio, setCateRadio] = useState(\"all\");\n  const itemSort = (e) => {\n    setCateRadio(e.target.value);\n  };\n\n  //검색\n  const [searchInput, setSearchInput] = useState(\"\");\n  const onSearchChange = (e) => {\n    setSearchInput(e.target.value);\n  };\n\n  const [SearchAgain, setSearchAgain] = useState(false);\n  const onSearch = () => {\n    setSearchAgain(!SearchAgain);\n  };\n\n  const onToggleFavor = (e, name) => {\n    e.currentTarget.classList.toggle(\"true\");\n    firebase\n      .database()\n      .ref(\"users\")\n      .child(userInfo.uid)\n      .child(`favorite/${name}/add_favor`)\n      .transaction((pre) => {\n        return !pre;\n      });\n  };\n\n  let b_soldout;\n  useEffect(() => {\n    if (!userInfo) {\n      setTimeout(() => {\n        setSearchAgain(!SearchAgain);\n      }, 500);\n    }\n    let mounted = true;\n    if (mounted && userInfo) {\n      //즐찾\n      async function getProdItem() {\n        let favorItem = [];\n        await firebase\n          .database()\n          .ref(\"soldout\")\n          .once(\"value\")\n          .then((snapshot) => {\n            snapshot.forEach((el) => {\n              b_soldout = el.val();\n            });\n          });\n        await firebase\n          .database()\n          .ref(\"users\")\n          .child(`${userInfo.uid}/favorite`)\n          .once(\"value\")\n          .then((snapshot) => {\n            snapshot.forEach(function (item) {\n              favorItem.push({\n                name: item.key,\n                add_favor: item.val().add_favor,\n              });\n            });\n          });\n\n        await firebase\n          .database()\n          .ref(\"products\")\n          .orderByChild(\"sort_num\")\n          .once(\"value\")\n          .then((snapshot) => {\n            let array = [];\n            snapshot.forEach(function (item) {\n              array.push({\n                uid: item.key,\n                name: item.val().name,\n                kal: item.val().kal,\n                hot: item.val().hot,\n                category: item.val().category,\n                image: item.val().image,\n                price: parseInt(item.val().price),\n                add: item.val().add,\n                b_soldout: b_soldout,\n                soldout: item.val().soldout,\n                sort_num: item.val().sort_num ? item.val().sort_num : 9999,\n              });\n            });\n\n            let newFavorItem = [];\n            array.map((el) => {\n              let name = el.name;\n              favorItem.forEach((favor) => {\n                if (favor.name === name) {\n                  newFavorItem.push({\n                    ...favor,\n                    ...el,\n                  });\n                }\n              });\n              return el;\n            });\n            //array = { ...array, ...newFavorItem };\n            newFavorItem.map((el) => {\n              let uid = el.uid;\n              let favor = el.add_favor;\n              array.forEach((el) => {\n                if (el.uid === uid) {\n                  el.add_favor = favor;\n                }\n                return el;\n              });\n            });\n\n            array.sort((a, b) => {\n              return a.sort_num - b.sort_num;\n            });\n\n            array = array.filter((el) => {\n              if (CateRadio === \"all\") {\n                return el;\n              }\n              return el.category === CateRadio;\n            });\n            setProdItem(array);\n          });\n\n        if (searchInput !== \"\") {\n          let array = _.cloneDeep(ProdItem);\n          array.forEach(function (item) {\n            var dis = Hangul.disassemble(item.name, true);\n            var cho = dis.reduce(function (prev, elem) {\n              elem = elem[0] ? elem[0] : elem;\n              return prev + elem;\n            }, \"\");\n            item.diassembled = cho;\n          });\n          let arr = searchInput.concat();\n          let search = Hangul.disassemble(arr).join(\"\");\n          array = array.filter(function (item) {\n            return (\n              item.diassembled.includes(searchInput) ||\n              item.diassembled.includes(search) ||\n              item.name.includes(searchInput)\n            );\n          });\n          setProdItem(array);\n        }\n      }\n      getProdItem();\n    }\n    return function cleanup() {\n      mounted = false;\n    };\n  }, [CateRadio, searchInput, SearchAgain]);\n\n  const [PosX, setPosX] = useState(0);\n  const [PosY, setPosY] = useState(0);\n  const [OnModal, setOnModal] = useState(false);\n  const [OrderItem, setOrderItem] = useState();\n  const orderHandler = (e, item) => {\n    if (e.target.tagName !== \"svg\" && e.target.tagName !== \"path\") {\n      if (b_soldout === false) {\n        item.add = \"\";\n      }\n      setOrderItem(item);\n      setPosX(e.clientX);\n      setPosY(e.clientY);\n      setOnModal(true);\n    }\n  };\n  const onFinished = () => {\n    setOnModal(false);\n  };\n\n  const TopBox = (\n    <>\n      <Search\n        style={{ marginBottom: \"10px\" }}\n        allowClear\n        enterButton=\"검색\"\n        size=\"large\"\n        placeholder=\"실시간 검색(초성가능)\"\n        value={searchInput}\n        onSearch={onSearch}\n        onChange={onSearchChange}\n        type=\"text\"\n      />\n      <div className=\"menuCategory\">\n        <Radio.Group\n          className=\"menuCategory\"\n          onChange={itemSort}\n          defaultValue=\"all\"\n          buttonStyle=\"solid\"\n        >\n          <Radio.Button value=\"all\">전체</Radio.Button>\n          <Radio.Button value=\"커피\">커피</Radio.Button>\n          <Radio.Button value=\"라떼\">라떼</Radio.Button>\n          <Radio.Button value=\"에이드\">에이드</Radio.Button>\n          <Radio.Button value=\"차\">차</Radio.Button>\n          <Radio.Button value=\"프로틴\">프로틴</Radio.Button>\n          <Radio.Button value=\"스낵\">스낵</Radio.Button>\n          <Radio.Button value=\"주스\">주스</Radio.Button>\n        </Radio.Group>\n      </div>\n    </>\n  );\n\n  if (ProdItem.length) {\n    return (\n      <>\n        {TopBox}\n        <ProdList>\n          {ProdItem.map((item, index) => (\n            <div\n              style={{ cursor: \"pointer\", position: \"relative\" }}\n              className={`ani-fadein list delay-${index}`}\n              key={index}\n            >\n              {item.soldout === false && (\n                <div\n                  style={{\n                    width: \"100%\",\n                    height: \"100%\",\n                    position: \"absolute\",\n                    left: \"0\",\n                    top: \"0\",\n                    display: \"flex\",\n                    fontSize: \"14px\",\n                    color: \"#fff\",\n                    justifyContent: \"center\",\n                    alignItems: \"center\",\n                    background: \"rgba(0,0,0,0.5)\",\n                    zIndex: \"10\",\n                  }}\n                >\n                  solout\n                </div>\n              )}\n              <div className=\"img\" onClick={(e) => orderHandler(e, item)}>\n                <span style={{ opacity: \"0.85\" }} className=\"kal\">\n                  {item.kal}kal\n                </span>\n                <img src={item.image} alt=\"\" />\n              </div>\n              <div className=\"user-box\" onClick={(e) => orderHandler(e, item)}>\n                <div className=\"txt\" style={{ padding: \"0 5px\" }}>\n                  <div className=\"flex-box between\">\n                    <span className=\"name\">{item.name}</span>\n                    <span\n                      className={\"ic-favor \" + item.add_favor}\n                      onClick={(e) => {\n                        onToggleFavor(e, item.name);\n                      }}\n                    >\n                      <antIcon.AiFillStar className=\"favor\" />\n                      <antIcon.AiOutlineStar className=\"no-favor\" />\n                    </span>\n                  </div>\n                  <div className=\"flex-box between a-center\">\n                    <span className=\"hot\">\n                      {item.hot === \"etc\" ? \"\" : item.hot}\n                    </span>\n                    <span\n                      style={{\n                        textDecoration: \"line-through\",\n                        color: \"#888\",\n                      }}\n                      className=\"price\"\n                    >\n                      {commaNumber(item.price)}원\n                    </span>\n                  </div>\n                </div>\n              </div>\n            </div>\n          ))}\n        </ProdList>\n        {OnModal && (\n          <OderModalPopup\n            onFinished={onFinished}\n            posx={PosX}\n            posy={PosY}\n            OrderItem={OrderItem}\n          />\n        )}\n      </>\n    );\n  } else if (searchInput) {\n    return (\n      <>\n        {TopBox}\n        <div style={{ paddingTop: \"15px\" }}>\n          <Empty\n            description={\n              <span>\n                검색결과가 없습니다.\n                <br />\n                ※검색어가 제대로 입력된 경우엔 검색버튼을 다시 눌러보세요.\n              </span>\n            }\n            image={Empty.PRESENTED_IMAGE_SIMPLE}\n          />\n        </div>\n      </>\n    );\n  } else {\n    return (\n      <>\n        {TopBox}\n        <Loading />\n      </>\n    );\n  }\n}\n\nexport default Menu;\n",["110","111"],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\MyMenu.js",["112","113"],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Nav.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Admin\\AdminProd.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\redux\\reducers\\user_reducer.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\firebaseConfig.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Admin\\ModifyModal.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\CommonFunc.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\redux\\actions\\types.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Admin\\ImgUpload.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\OrderModal.js",[],{"ruleId":"114","severity":1,"message":"115","line":37,"column":6,"nodeType":"116","endLine":37,"endColumn":8,"suggestions":"117"},{"ruleId":"114","severity":1,"message":"118","line":52,"column":6,"nodeType":"116","endLine":52,"endColumn":8,"suggestions":"119"},{"ruleId":"120","severity":1,"message":"121","line":61,"column":9,"nodeType":"122","messageId":"123","endLine":61,"endColumn":34},{"ruleId":"124","severity":1,"message":"125","line":69,"column":19,"nodeType":"126","messageId":"127","endLine":69,"endColumn":21},{"ruleId":"120","severity":1,"message":"128","line":76,"column":10,"nodeType":"122","messageId":"123","endLine":76,"endColumn":16},{"ruleId":"129","severity":1,"message":"130","line":103,"column":11,"nodeType":"131","endLine":103,"endColumn":54},{"ruleId":"132","severity":1,"message":"133","line":103,"column":19,"nodeType":"134","messageId":"135","endLine":103,"endColumn":33},{"ruleId":"114","severity":1,"message":"136","line":189,"column":6,"nodeType":"116","endLine":189,"endColumn":19,"suggestions":"137"},{"ruleId":"114","severity":1,"message":"138","line":64,"column":25,"nodeType":"139","endLine":64,"endColumn":49},{"ruleId":"140","severity":1,"message":"141","line":117,"column":35,"nodeType":"142","messageId":"143","endLine":117,"endColumn":37},{"ruleId":"144","replacedBy":"145"},{"ruleId":"146","replacedBy":"147"},{"ruleId":"140","severity":1,"message":"141","line":141,"column":32,"nodeType":"142","messageId":"143","endLine":141,"endColumn":34},{"ruleId":"114","severity":1,"message":"148","line":156,"column":6,"nodeType":"116","endLine":156,"endColumn":16,"suggestions":"149"},"react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'dispatch' and 'history'. Either include them or remove the dependency array.","ArrayExpression",["150"],"React Hook useEffect has a missing dependency: 'userInfo.uid'. Either include it or remove the dependency array.",["151"],"no-unused-vars","'getNotificationPermission' is assigned a value but never used.","Identifier","unusedVar","eqeqeq","Expected '===' and instead saw '=='.","BinaryExpression","unexpected","'notify' is defined but never used.","jsx-a11y/anchor-is-valid","The href attribute requires a valid value to be accessible. Provide a valid, navigable address as the href value. If you cannot provide a valid href, but still need the element to resemble a link, use a button and change it with appropriate styles. Learn more: https://github.com/evcohen/eslint-plugin-jsx-a11y/blob/master/docs/rules/anchor-is-valid.md","JSXOpeningElement","no-script-url","Script URL is a form of eval.","Literal","unexpectedScriptURL","React Hook useEffect has a missing dependency: 'Sound'. Either include it or remove the dependency array.",["152"],"Assignments to the 'b_soldout' variable from inside React Hook useEffect will be lost after each render. To preserve the value over time, store it in a useRef Hook and keep the mutable value in the '.current' property. Otherwise, you can move this variable directly inside useEffect.","MemberExpression","array-callback-return","Array.prototype.map() expects a return value from arrow function.","ArrowFunctionExpression","expectedInside","no-native-reassign",["153"],"no-negated-in-lhs",["154"],"React Hook useEffect has missing dependencies: 'FavorItem', 'ProdItem', and 'userInfo.uid'. Either include them or remove the dependency array.",["155"],{"desc":"156","fix":"157"},{"desc":"158","fix":"159"},{"desc":"160","fix":"161"},"no-global-assign","no-unsafe-negation",{"desc":"162","fix":"163"},"Update the dependencies array to be: [dispatch, history]",{"range":"164","text":"165"},"Update the dependencies array to be: [userInfo.uid]",{"range":"166","text":"167"},"Update the dependencies array to be: [Sound, SoundSelect]",{"range":"168","text":"169"},"Update the dependencies array to be: [FavorItem, ProdItem, SortItem, userInfo.uid]",{"range":"170","text":"171"},[1350,1352],"[dispatch, history]",[1532,1534],"[userInfo.uid]",[4123,4136],"[Sound, SoundSelect]",[4562,4572],"[FavorItem, ProdItem, SortItem, userInfo.uid]"]