in\\AdminOrder.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Admin\\Admin.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\redux\\actions\\user_action.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\redux\\reducers\\user_reducer.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\redux\\actions\\types.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Admin\\ImgUpload.js",["106"],"import React, { useState } from \"react\";\r\nimport styled from \"styled-components\";\r\n\r\nexport const FileLabel = styled.label`\r\n  display: flex;\r\n  width: 60px;\r\n  height: 60px;\r\n  border: 1px solid #ddd;\r\n  border-radius: 5px;\r\n  flex-shrink: 0;\r\n  justify-content: center;\r\n  align-items: center;\r\n  font-size: 12px;\r\n  color: #888;\r\n  cursor: pointer;\r\n  overflow: hidden;\r\n  img {\r\n    width: 100%;\r\n    height: auto;\r\n  }\r\n`;\r\n\r\nfunction ImgUpload({ onImgFile }) {\r\n  const [ProdImg, setProdImg] = useState();\r\n  const handleChange = (e) => {\r\n    onImgFile(e);\r\n    let reader = new FileReader();\r\n    reader.onload = function (event) {\r\n      setProdImg(event.target.result);\r\n    };\r\n    reader.readAsDataURL(e.target.files[0]);\r\n    setProdImg(e.target.files[0]);\r\n  };\r\n\r\n  return (\r\n    <>\r\n      <input\r\n        style={{ display: \"none\" }}\r\n        type=\"file\"\r\n        id=\"imgFile1\"\r\n        onChange={handleChange}\r\n      />\r\n      <FileLabel htmlFor=\"imgFile1\" style={{ marginRight: \"5px\" }}>\r\n        {ProdImg && <img src={`${ProdImg}`} alt=\"\" />}\r\n        {!ProdImg && `이미지`}\r\n      </FileLabel>\r\n    </>\r\n  );\r\n}\r\n\r\nexport default ImgUpload;\r\n","C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Admin\\ModifyModal.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Menu.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\OrderModal.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\CommonFunc.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\MyOrder.js",["107"],"import { Button } from \"antd\";\r\nimport React, { useState, useEffect } from \"react\";\r\nimport firebase from \"../firebase\";\r\nimport { Popover } from \"antd\";\r\nimport { commaNumber } from \"./CommonFunc\";\r\nimport { useSelector } from \"react-redux\";\r\nimport { OrderBox } from \"./Admin/AdminOrder\";\r\nimport Loading from \"./Loading\";\r\nimport { Empty } from 'antd';\r\n\r\nfunction MyOrder() {\r\n  const userInfo = useSelector((state) => state.user.currentUser);\r\n  const [OrderList, setOrderList] = useState([]);\r\n  const [Nodata, setNodata] = useState(false);\r\n\r\n  useEffect(() => {\r\n    let mounted = true;\r\n    if (mounted) {\r\n      firebase\r\n        .database()\r\n        .ref(\"order\")\r\n        .orderByChild(\"order_uid\")\r\n        .equalTo(userInfo.uid)\r\n        .limitToFirst(30)\r\n        .on(\"value\", (snapshot) => {          \r\n          let array = [];\r\n          snapshot.forEach(function (item) {\r\n            array.push({\r\n              ...item.val(),\r\n              key: item.key,\r\n            });\r\n          });          \r\n          // eslint-disable-next-line array-callback-return\r\n          array.sort((a, b) => {\r\n            if (a.timestamp < b.timestamp) {\r\n              return 1;\r\n            }\r\n            if (a.timestamp > b.timestamp) {\r\n              return -1;\r\n            }\r\n          });\r\n          setOrderList(array);\r\n          if(array.length === 0){\r\n              setNodata(true)\r\n          }\r\n        });\r\n    }\r\n    return function cleanup() {\r\n      mounted = false;\r\n    };\r\n  }, []);\r\n\r\n  if (OrderList.length) {\r\n    return (\r\n      <>\r\n        <h3 className=\"title\">주문내역</h3>\r\n        <OrderBox>\r\n          {OrderList.map((list, index) => (\r\n            <div className={`list state_${list.order_state}`} key={index}>\r\n              <span style={{ display: \"none\" }}>{list.key}</span>\r\n              <div className=\"prod\">\r\n                <div className=\"info-box\">\r\n                  <span className=\"info\">{list.prod_name}</span>\r\n                  {list.hot === \"hot\" ? (\r\n                    <span className=\"ic-hot\"></span>\r\n                  ) : list.hot === \"ice\" ? (\r\n                    <span className=\"ic-ice\"></span>\r\n                  ) : (\r\n                    \"\"\r\n                  )}\r\n                  <span className=\"info\">{list.amount}개</span>\r\n                  {\r\n                  list.add &&\r\n                  list.add.map((el,index) => (\r\n                    <>\r\n                      <span className=\"info\" key={index}>{el}</span>\r\n                    </>\r\n                  ))\r\n                }\r\n                  {list.order_etc && (\r\n                    <Popover content={list.order_etc} trigger=\"click\">\r\n                      <Button type=\"default\">기타</Button>\r\n                    </Popover>\r\n                  )}\r\n                </div>\r\n                <span>{commaNumber(list.price)}원</span>\r\n              </div>\r\n              <div className=\"state\">\r\n                <span className=\"date\">\r\n                  {list.order_time.split(\"|\")[0]}&nbsp; (\r\n                  {list.order_time.split(\"|\")[1]})\r\n                </span>\r\n                <span>{list.order_state === 0 ? \"대기중\" : \"완료\"}</span>\r\n              </div>\r\n            </div>\r\n          ))}\r\n        </OrderBox>\r\n      </>\r\n    );\r\n  }else if(Nodata){\r\n    return (\r\n      <>\r\n        <Empty \r\n        description=\"주문내역이 없습니다.\"\r\n        image={Empty.PRESENTED_IMAGE_SIMPLE} \r\n        >          \r\n        </Empty>\r\n      </>\r\n    )\r\n  } else {\r\n    return (\r\n      <>\r\n        <Loading />\r\n      </>\r\n    );\r\n  }\r\n}\r\n\r\nexport default MyOrder;\r\n","C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\firebaseConfig.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\Admin\\AdminOrderList.js",[],{"ruleId":"108","replacedBy":"109"},{"ruleId":"110","replacedBy":"111"},{"ruleId":"112","severity":1,"message":"113","line":36,"column":6,"nodeType":"114","endLine":36,"endColumn":8,"suggestions":"115"},{"ruleId":"116","severity":1,"message":"117","line":42,"column":7,"nodeType":"118","messageId":"119","endLine":42,"endColumn":19},{"ruleId":"116","severity":1,"message":"120","line":43,"column":7,"nodeType":"118","messageId":"119","endLine":43,"endColumn":19},{"ruleId":"121","severity":1,"message":"122","line":31,"column":27,"nodeType":"123","endLine":31,"endColumn":53},{"ruleId":"112","severity":1,"message":"124","line":51,"column":6,"nodeType":"114","endLine":51,"endColumn":8,"suggestions":"125"},"no-native-reassign",["126"],"no-negated-in-lhs",["127"],"react-hooks/exhaustive-deps","React Hook useEffect has missing dependencies: 'dispatch' and 'history'. Either include them or remove the dependency array.","ArrayExpression",["128"],"no-unused-vars","'clientHeight' is assigned a value but never used.","Identifier","unusedVar","'scrollHeight' is assigned a value but never used.","jsx-a11y/alt-text","img elements must have an alt prop, either with meaningful text, or an empty string for decorative images.","JSXOpeningElement","React Hook useEffect has a missing dependency: 'userInfo.uid'. Either include it or remove the dependency array.",["129"],"no-global-assign","no-unsafe-negation",{"desc":"130","fix":"131"},{"desc":"132","fix":"133"},"Update the dependencies array to be: [dispatch, history]",{"range":"134","text":"135"},"Update the dependencies array to be: [userInfo.uid]",{"range":"136","text":"137"},[1300,1302],"[dispatch, history]",[1504,1506],"[userInfo.uid]"]