r\";\nimport Loading from \"./component/Loading\";\nimport { Layout } from \"antd\";\nimport firebase from \"./firebase\";\nimport { useDispatch, useSelector } from \"react-redux\";\nimport { setUser, clearUser } from \"./redux/actions/user_action\";\n\nconst { Sider, Content } = Layout;\n\nfunction App(props) {\n  let history = useHistory();\n  let dispatch = useDispatch();\n  const isLoading = useSelector((state) => state.user.isLoading);\n\n  useEffect(() => {\n    firebase.auth().onAuthStateChanged((user) => {\n      if (user) {\n        history.push(\"/\");\n        dispatch(setUser(user));\n      } else {\n        history.push(\"/login\");\n        dispatch(clearUser());\n      }\n    });\n  }, []);\n  if (isLoading) {\n    return (\n      <>\n        <Layout>\n          <Sider className=\"nav-wrap\">\n            <Nav />\n          </Sider>\n          <Content className=\"content-box\">\n            <Loading />\n          </Content>\n        </Layout>\n      </>\n    );\n  } else {\n    return (\n      <>\n        <Layout>\n          <Sider className=\"nav-wrap\">\n            <Nav />\n          </Sider>\n          <Content className=\"content-box\">\n            <Switch>\n              <Route exact path=\"/\" component={LandingPage} />\n              <Route exact path=\"/login\" component={Login} />\n              <Route exact path=\"/join\" component={Join} />\n              <Route exact path=\"/admin\" component={Admin} />\n              <Route exact path=\"/admin/prod\" component={AdminProd} />\n              <Route exact path=\"/admin/order\" component={AdminOrder} />\n            </Switch>\n          </Content>\n        </Layout>\n      </>\n    );\n  }\n}\n\nexport default App;\n","C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\firebase.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\redux\\reducers\\index.js",[],"C:\\Users\\ROK\\Desktop\\프로젝트\\react\\react-order\\src\\component\\LandingPage.js",[],"C:\\Users\\ROK\\Desktop\\프로젝